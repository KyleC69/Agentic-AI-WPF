<Page
    x:Class="RAGDataIngestionWPF.Views.BlankPage"
    Style="{DynamicResource MahApps.Styles.Page}"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:properties="clr-namespace:RAGDataIngestionWPF.Properties"
    mc:Ignorable="d" Background="{DynamicResource MahApps.Brushes.Window.Background.Backdrop.Acrylic}"
    d:DesignHeight="450" d:DesignWidth="800">
    <Grid ShowGridLines="True">
        <Grid.RowDefinitions>
            <RowDefinition Height="48" />
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <TextBlock Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3"
                   Style="{StaticResource PageTitleStyle}"
                   Text="{x:Static properties:Resources.BlankPageTitle}" />
        <Grid Grid.Row="1">
            <Grid Grid.Row="2" Grid.Column="2">
            <Border CornerRadius="30" Background="{DynamicResource MahApps.Brushes.Control.Background}">
                <GroupBox Header="Agents">

                    <GroupItem>

                    <StackPanel VerticalAlignment="Stretch" Orientation="Vertical">
                            <ListBox x:Name="AgentBox" VerticalAlignment="Stretch">
                                <ListBoxItem Content="Default"/>
                            </ListBox>
                            <Button x:Name="AddAgent" Content="Add Agent" Click="AddAgent_OnClick" />
                        </StackPanel>
                    </GroupItem>
                </GroupBox>
            </Border>
        </Grid>
    </Grid>
        <Grid Grid.Row="1" Grid.Column="1">
            <Border CornerRadius="30" Padding="5" Background="{DynamicResource MahApps.Brushes.Control.Background}">
                <GroupBox Header="Orchestration">
                    <StackPanel>
                        <RadioButton GroupName="Orchestration" Content="None" />
                        <RadioButton GroupName="Orchestration" Content="Concurrent Group" />
                        <RadioButton GroupName="Orchestration" Content="Round Robin" />
                        <RadioButton GroupName="Orchestration" Content="Sequential" />
                    </StackPanel>
                </GroupBox>
            </Border>
        </Grid>
        <Grid Grid.Row="1" Grid.Column="2">
            <Border CornerRadius="30" Background="{DynamicResource MahApps.Brushes.Control.Background}">
                <GroupBox Header="Orchestration">
                    <StackPanel />
                </GroupBox>
            </Border>
        </Grid>
        <Grid Grid.Row="2" Grid.Column="1">
            <Border CornerRadius="30" Background="{DynamicResource MahApps.Brushes.Control.Background}">
                <GroupBox Header="Orchestration">
                    <StackPanel />
                </GroupBox>
            </Border>
        </Grid>
        <Grid Grid.Row="2" Grid.Column="2">
            <Border CornerRadius="30" Background="{DynamicResource MahApps.Brushes.Control.Background}">
                <GroupBox Header="Orchestration">
                    <StackPanel />
                </GroupBox>
            </Border>
        </Grid>
    </Grid>
</Page>