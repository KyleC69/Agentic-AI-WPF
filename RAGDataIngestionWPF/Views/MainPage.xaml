<Page
    x:Class="RAGDataIngestionWPF.Views.MainPage"
    Style="{DynamicResource MahApps.Styles.Page}"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:properties="clr-namespace:RAGDataIngestionWPF.Properties"
    mc:Ignorable="d"
    d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="48" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <TextBlock
            Style="{StaticResource PageTitleStyle}"
            Margin="{StaticResource MediumLeftMargin}"
            Text="{x:Static properties:Resources.MainPageTitle}" />
        <Grid
            Grid.Row="1"
            Margin="{StaticResource MediumLeftRightMargin}"
            Background="{DynamicResource MahApps.Brushes.Gray10}">
            <Grid Margin="{StaticResource SmallTopBottomMargin}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock
                    Margin="{StaticResource SmallLeftMargin}"
                    Style="{StaticResource BodyTextStyle}"
                    Text="{Binding ContextTokenCount, StringFormat=Context tokens: {0} / 120000}" />

                <ListBox
                    Grid.Row="1"
                    Margin="{StaticResource XSmallTopMargin}"
                    BorderThickness="0"
                    Background="Transparent"
                    ItemsSource="{Binding Messages}"
                    ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border
                                Margin="0,4"
                                Padding="10"
                                MaxWidth="700"
                                HorizontalAlignment="Left"
                                Background="{DynamicResource MahApps.Brushes.Gray8}">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="HorizontalAlignment" Value="Left" />
                                        <Setter Property="Background" Value="{DynamicResource MahApps.Brushes.Gray8}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsUser}" Value="True">
                                                <Setter Property="HorizontalAlignment" Value="Right" />
                                                <Setter Property="Background" Value="{DynamicResource MahApps.Brushes.Gray6}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel>
                                    <TextBlock
                                        FontWeight="SemiBold"
                                        Text="{Binding Role}" />
                                    <TextBlock
                                        Margin="0,6,0,0"
                                        TextWrapping="Wrap"
                                        Text="{Binding FormattedContent}" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <Grid Grid.Row="2" Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBox
                        Grid.Column="0"
                        MinHeight="72"
                        AcceptsReturn="True"
                        VerticalContentAlignment="Top"
                        TextWrapping="Wrap"
                        VerticalScrollBarVisibility="Auto"
                        Text="{Binding MessageInput, UpdateSourceTrigger=PropertyChanged}" />
                    <Button
                        Grid.Column="1"
                        Margin="8,0,0,0"
                        VerticalAlignment="Bottom"
                        Command="{Binding SendMessageCommand}"
                        Content="Send" />
                    <Button
                        Grid.Column="2"
                        Margin="8,0,0,0"
                        VerticalAlignment="Bottom"
                        Command="{Binding CancelMessageCommand}"
                        Content="Cancel" />
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Page>
